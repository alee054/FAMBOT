# Token del bot Telegram (da BotFather). Serve sia per validare l'accesso
# alla Mini App (initData) sia per inviare messaggi (liste, promemoria, bacheca).
BOT_TOKEN=

# Whitelist dei 4 Telegram id ammessi, separati da virgola.
# Senza questa variabile l'app resterebbe aperta a chiunque abbia il link: da impostare sempre.
ALLOWED_TELEGRAM_IDS=

# Stringa di connessione Postgres. Se assente in sviluppo locale si usa
# automaticamente pg-mem (Postgres in-memory, dati persi al riavvio).
DATABASE_URL=

# Porta del server (default 3000 se assente).
PORT=3000

# Se "1" (solo fuori produzione) salta la validazione initData e simula un
# utente finto, per sviluppare senza aprire l'app da Telegram.
DEV_BYPASS_AUTH=
